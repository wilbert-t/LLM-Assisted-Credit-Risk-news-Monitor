# =============================================================================
# Credit Risk Monitor — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# PostgreSQL connection string. Matches the service defined in docker-compose.yml.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/credit_risk

# -----------------------------------------------------------------------------
# News APIs
# NewsAPI: https://newsapi.org — free tier allows 100 requests/day.
# GDELT: public API, no key required but base URL may change.
# -----------------------------------------------------------------------------
NEWSAPI_KEY=your_newsapi_key_here
GDELT_API=http://api.gdeltproject.org/api/v2

# -----------------------------------------------------------------------------
# LLM — Groq (active provider, Week 1–4)
# Get key at: https://console.groq.com
# -----------------------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here

# -----------------------------------------------------------------------------
# LLM — Anthropic Claude (future use, currently commented out)
# Get key at: https://console.anthropic.com
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=your_claude_api_key_here

# -----------------------------------------------------------------------------
# LLM Model Selection
# Switch LLM_PROVIDER to "anthropic" and update LLM_MODEL when ready to migrate.
# -----------------------------------------------------------------------------
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# -----------------------------------------------------------------------------
# Application Settings
# DEBUG=true enables verbose output. Set ENVIRONMENT=production for deploys.
# BATCH_SIZE controls how many articles are processed per job run.
# MAX_WORKERS sets the thread pool size for concurrent requests.
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
ENVIRONMENT=development
DEBUG=true
BATCH_SIZE=50
MAX_WORKERS=4
